<section class="shop-by-room-section">

  <h2>{{ section.settings.heading }}</h2>

  <div class="room-grid">
    {% content_for 'blocks' %}
  </div>

</section>


{% schema %}
{
  "name": "Shop by Room",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Shop by Room"
    }
  ],
  "blocks": [
    {
      "type": "@theme"
    }
  ],
  "presets": [
    {
      "name": "Shop by Room"
    }
  ]
}
{% endschema %}