<section
class="product-logic-demo"
style="background-color: {{ section.settings.background_color }};
color: {{ section.settings.text_color }};
padding:40px;"
>

<h2>{{ section.settings.heading }}</h2>

{% assign product = all_products[section.settings.product] %}

{% if product != blank %}

<div class="product-card">

{% if product.featured_image %}
<img
src="{{ product.featured_image | image_url: width: 500 }}"
alt="{{ product.title }}"
class="logic-product-image"
loading="lazy"

>
{% endif %}

<h3>{{ product.title }}</h3>

<p class="price">
{{ section.settings.price_label }}:
{{ product.price | money }}
</p>


{% if product.price > 200000 %}

<p class="badge premium">
{{ section.settings.premium_text }}
</p>

{% else %}

<p class="badge budget">
{{ section.settings.budget_text }}
</p>

{% endif %}



<p class="type-heading">
{{ section.settings.type_heading }}
</p>

{% case product.type %}

{% when "Home Decor" %}

<p>{{ section.settings.home_decor_text }}</p>

{% when "Lighting" %}

<p>{{ section.settings.lighting_text }}</p>

{% else %}

<p>{{ section.settings.default_text }}</p>

{% endcase %}



{% if product.tags.size > 0 %}

<p>{{ section.settings.tag_heading }}</p>

<ul class="tag-list">

{% for tag in product.tags %}

<li>{{ tag | capitalize }}</li>

{% endfor %}

</ul>

{% endif %}

</div>

{% else %}

<p>Please select a product.</p>

{% endif %}

</section>


<style>

.product-card{
max-width:400px;
margin:auto;
text-align:center;
}

.logic-product-image{
width:100%;
height:auto;
margin-bottom:15px;
border-radius:8px;
}

.price{
font-size:18px;
margin-bottom:10px;
}

.badge{
font-weight:600;
margin-bottom:10px;
}

.tag-list{
list-style:none;
padding:0;
}

.tag-list li{
display:inline-block;
margin:4px;
padding:4px 10px;
background:#eee;
border-radius:20px;
font-size:13px;
}

</style>


{% schema %}
{
"name": "Liquid Logic Demo",
"settings": [

{
"type": "text",
"id": "heading",
"label": "Section Heading",
"default": "Featured Decor"
},

{
"type": "product",
"id": "product",
"label": "Select Product"
},

{
"type": "color",
"id": "background_color",
"label": "Background Color",
"default": "#f5f5f5"
},

{
"type": "color",
"id": "text_color",
"label": "Text Color",
"default": "#000000"
},

{
"type": "text",
"id": "price_label",
"label": "Price Label",
"default": "Price"
},

{
"type": "text",
"id": "premium_text",
"label": "Premium Product Text",
"default": "Premium Decor"
},

{
"type": "text",
"id": "budget_text",
"label": "Budget Product Text",
"default": "Budget Friendly"
},

{
"type": "text",
"id": "type_heading",
"label": "Product Type Heading",
"default": "Product Category"
},

{
"type": "text",
"id": "home_decor_text",
"label": "Home Decor Message",
"default": "Perfect decorative piece for your home."
},

{
"type": "text",
"id": "lighting_text",
"label": "Lighting Message",
"default": "Enhance your space with elegant lighting."
},

{
"type": "text",
"id": "default_text",
"label": "Default Message",
"default": "Beautiful decor item."
},

{
"type": "text",
"id": "tag_heading",
"label": "Tag Heading",
"default": "Product Tags"
}

],

"presets":[
{
"name":"Liquid Logic Demo"
}
]

}
{% endschema %}