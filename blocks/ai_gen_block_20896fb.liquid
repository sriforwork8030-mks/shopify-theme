{% doc %}
  @prompt
    Collapsible row, i need 3 rows which only means collapisible row 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-collapsible-rows-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-collapsible-row-item-{{ ai_gen_id }} {
    border-top: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
  }

  .ai-collapsible-row-item-{{ ai_gen_id }}:last-child {
    border-bottom: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
  }

  .ai-collapsible-row-header-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    padding: {{ block.settings.padding }}px 0;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    gap: 16px;
  }

  .ai-collapsible-row-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0;
    flex-grow: 1;
  }

  .ai-collapsible-row-icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    transition: transform 0.3s ease;
    color: {{ block.settings.icon_color }};
  }

  .ai-collapsible-row-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
  }

  .ai-collapsible-row-item-{{ ai_gen_id }} details[open] .ai-collapsible-row-icon-{{ ai_gen_id }} {
    transform: rotate(180deg);
  }

  .ai-collapsible-row-content-{{ ai_gen_id }} {
    padding: 0 0 {{ block.settings.padding }}px 0;
    color: {{ block.settings.content_color }};
    font-size: {{ block.settings.content_size }}px;
    line-height: 1.6;
  }

  .ai-collapsible-row-content-{{ ai_gen_id }} p {
    margin: 0 0 12px 0;
  }

  .ai-collapsible-row-content-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }
{% endstyle %}

<collapsible-rows-{{ ai_gen_id }}
  class="ai-collapsible-rows-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% for i in (1..3) %}
    {% liquid
      assign row_enabled_key = 'row_' | append: i | append: '_enabled'
      assign row_title_key = 'row_' | append: i | append: '_title'
      assign row_content_key = 'row_' | append: i | append: '_content'
      assign row_open_key = 'row_' | append: i | append: '_open'

      assign row_enabled = block.settings[row_enabled_key]
      assign row_title = block.settings[row_title_key]
      assign row_content = block.settings[row_content_key]
      assign row_open = block.settings[row_open_key]
    %}

    {% if row_enabled %}
      <div class="ai-collapsible-row-item-{{ ai_gen_id }}">
        <details {% if row_open %}open{% endif %}>
          <summary class="ai-collapsible-row-header-{{ ai_gen_id }}">
            <h3 class="ai-collapsible-row-title-{{ ai_gen_id }}">
              {{ row_title }}
            </h3>
            <span class="ai-collapsible-row-icon-{{ ai_gen_id }}">
              {% if block.settings.icon_style == 'chevron' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              {% elsif block.settings.icon_style == 'plus' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="12" y1="5" x2="12" y2="19"></line>
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                </svg>
              {% else %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              {% endif %}
            </span>
          </summary>
          <div class="ai-collapsible-row-content-{{ ai_gen_id }}">
            {{ row_content }}
          </div>
        </details>
      </div>
    {% endif %}
  {% endfor %}
</collapsible-rows-{{ ai_gen_id }}>

<script>
  (function() {
    class CollapsibleRows{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.summaries = this.querySelectorAll('summary');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.summaries.forEach((summary) => {
          summary.addEventListener('click', this.handleClick.bind(this));
        });
      }

      handleClick(event) {
        event.preventDefault();
        const details = event.currentTarget.parentElement;
        details.open = !details.open;
      }

      disconnectedCallback() {
        this.summaries.forEach((summary) => {
          summary.removeEventListener('click', this.handleClick.bind(this));
        });
      }
    }

    customElements.define('collapsible-rows-{{ ai_gen_id }}', CollapsibleRows{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Collapsible rows",
  "settings": [
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Padding",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "border_width",
      "label": "Border width",
      "min": 0,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#e6e6e6"
    },
    {
      "type": "header",
      "content": "Title"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Size",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Content text"
    },
    {
      "type": "range",
      "id": "content_size",
      "label": "Size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "content_color",
      "label": "Color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Icon"
    },
    {
      "type": "select",
      "id": "icon_style",
      "label": "Style",
      "options": [
        {
          "value": "chevron",
          "label": "Chevron"
        },
        {
          "value": "plus",
          "label": "Plus"
        }
      ],
      "default": "chevron"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Size",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Row 1"
    },
    {
      "type": "checkbox",
      "id": "row_1_enabled",
      "label": "Enable row 1",
      "default": true
    },
    {
      "type": "text",
      "id": "row_1_title",
      "label": "Title",
      "default": "Shipping information"
    },
    {
      "type": "richtext",
      "id": "row_1_content",
      "label": "Content",
      "default": "<p>Free shipping on orders over ₹500. Standard delivery takes 3-5 business days.</p>"
    },
    {
      "type": "checkbox",
      "id": "row_1_open",
      "label": "Open by default",
      "default": false
    },
    {
      "type": "header",
      "content": "Row 2"
    },
    {
      "type": "checkbox",
      "id": "row_2_enabled",
      "label": "Enable row 2",
      "default": true
    },
    {
      "type": "text",
      "id": "row_2_title",
      "label": "Title",
      "default": "Return policy"
    },
    {
      "type": "richtext",
      "id": "row_2_content",
      "label": "Content",
      "default": "<p>Returns accepted within 30 days of purchase. Items must be unused and in original packaging.</p>"
    },
    {
      "type": "checkbox",
      "id": "row_2_open",
      "label": "Open by default",
      "default": false
    },
    {
      "type": "header",
      "content": "Row 3"
    },
    {
      "type": "checkbox",
      "id": "row_3_enabled",
      "label": "Enable row 3",
      "default": true
    },
    {
      "type": "text",
      "id": "row_3_title",
      "label": "Title",
      "default": "Care instructions"
    },
    {
      "type": "richtext",
      "id": "row_3_content",
      "label": "Content",
      "default": "<p>Clean with a soft, dry cloth. Avoid harsh chemicals and direct sunlight.</p>"
    },
    {
      "type": "checkbox",
      "id": "row_3_open",
      "label": "Open by default",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Collapsible rows"
    }
  ]
}
{% endschema %}
